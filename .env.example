# Application
NODE_ENV=production
APP_PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=cpanel
DB_PASSWORD=cpanel_secret_password
DB_NAME=cpanel_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_REFRESH_EXPIRATION=7d

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Agent
AGENT_SECRET=your-agent-communication-secret
AGENT_PORT=3002

# SSL / Let's Encrypt
LETSENCRYPT_EMAIL=admin@yourdomain.com

# Backup S3
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=backups
S3_REGION=us-east-1

# 2FA
TWO_FA_APP_NAME=ServerPanel
