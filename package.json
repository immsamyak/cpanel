{
  "name": "cpanel-server-management",
  "version": "1.0.0",
  "description": "Modern server management platform",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:agent": "cd agent && npm run start:dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build:agent": "cd agent && npm run build",
    "install:all": "cd backend && npm install && cd ../frontend && npm install && cd ../agent && npm install",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  }
}
